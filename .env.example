# ─── APP ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Supapi
NODE_ENV=development

# ─── PI NETWORK ────────────────────────────────────────────
# Dapatkan dari: develop.pi
NEXT_PUBLIC_PI_APP_ID=your_pi_app_id_here
PI_API_KEY=your_pi_api_key_here
NEXT_PUBLIC_PI_SANDBOX=true

# ─── SUPABASE ──────────────────────────────────────────────
# Dapatkan dari: supabase.com > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ─── AUTH / JWT ────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars
JWT_EXPIRES_IN=7d

# ─── RESEND (Email) ────────────────────────────────────────
# Dapatkan dari: resend.com > API Keys
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=noreply@supapi.app
RESEND_FROM_NAME=Supapi

# ─── SUPABASE STORAGE ──────────────────────────────────────
NEXT_PUBLIC_STORAGE_BUCKET=supapi-uploads
